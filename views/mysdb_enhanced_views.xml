    <!-- ========================================
         BULK ASSIGNMENT WIZARDS
         ======================================== -->

    <!-- Bulk Project Assignment Wizard -->
    <record id="view_mysdb_bulk_assign_project_wizard_form" model="ir.ui.view">
        <field name="name">mysdb.bulk.assign.project.wizard.form</field>
        <field name="model">mysdb.bulk.assign.project.wizard</field>
        <field name="arch" type="xml">
            <form string="Bulk Assign Products to Project">
                <group>
                    <group string="Target">
                        <field name="project_id" options="{'no_create': True}"/>
                    </group>
                    <group string="Filters">
                        <field name="store_id" options="{'no_create': True}"/>
                        <field name="assignment_filter"/>
                    </group>
                </group>
                <group>
                    <group>
                        <field name="replace_existing"/>
                    </group>
                    <group>
                        <label for="preview_count" string="Products Selected"/>
                        <div>
                            <field name="preview_count" class="oe_inline"/> products
                        </div>
                    </group>
                </group>
                <notebook>
                    <page string="Products to Assign">
                        <field name="product_ids" widget="many2many" nolabel="1"
                               context="{'search_default_filter_no_project': 1}"
                               options="{'no_create': True, 'no_open': True}">
                            <tree>
                                <field name="product_sku"/>
                                <field name="product_name"/>
                                <field name="store_id"/>
                                <field name="assignment_status" widget="badge" 
                                       decoration-success="assignment_status == 'complete'"
                                       decoration-warning="assignment_status == 'partial'"
                                       decoration-danger="assignment_status == 'none'"/>
                            </tree>
                        </field>
                    </page>
                </notebook>
                <footer>
                    <button name="action_assign" string="Assign Products" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_mysdb_bulk_assign_project" model="ir.actions.act_window">
        <field name="name">Bulk Assign to Project</field>
        <field name="res_model">mysdb.bulk.assign.project.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="binding_model_id" ref="model_mysdb_product"/>
        <field name="binding_view_types">list</field>
    </record>

    <!-- Bulk Marketing Assignment Wizard -->
    <record id="view_mysdb_bulk_assign_marketing_wizard_form" model="ir.ui.view">
        <field name="name">mysdb.bulk.assign.marketing.wizard.form</field>
        <field name="model">mysdb.bulk.assign.marketing.wizard</field>
        <field name="arch" type="xml">
            <form string="Bulk Assign Products to Marketing Account">
                <group>
                    <group string="Target">
                        <field name="account_id" options="{'no_create': True}"/>
                    </group>
                    <group string="Filters">
                        <field name="store_id" options="{'no_create': True}"/>
                        <field name="assignment_filter"/>
                    </group>
                </group>
                <group>
                    <group>
                    </group>
                    <group>
                        <label for="preview_count" string="Products Selected"/>
                        <div>
                            <field name="preview_count" class="oe_inline"/> products
                        </div>
                    </group>
                </group>
                <notebook>
                    <page string="Products to Assign">
                        <field name="product_ids" widget="many2many" nolabel="1"
                               context="{'search_default_filter_no_marketing': 1}"
                               options="{'no_create': True, 'no_open': True}">
                            <tree>
                                <field name="product_sku"/>
                                <field name="product_name"/>
                                <field name="store_id"/>
                                <field name="assignment_status" widget="badge" 
                                       decoration-success="assignment_status == 'complete'"
                                       decoration-warning="assignment_status == 'partial'"
                                       decoration-danger="assignment_status == 'none'"/>
                            </tree>
                        </field>
                    </page>
                </notebook>
                <footer>
                    <button name="action_assign" string="Assign Products" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_mysdb_bulk_assign_marketing" model="ir.actions.act_window">
        <field name="name">Bulk Assign to Marketing Account</field>
        <field name="res_model">mysdb.bulk.assign.marketing.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="binding_model_id" ref="model_mysdb_product"/>
        <field name="binding_view_types">list</field>
    </record>

    <!-- Bulk Period Creation Wizard -->
    <record id="view_mysdb_bulk_period_creation_wizard_form" model="ir.ui.view">
        <field name="name">mysdb.bulk.period.creation.wizard.form</field>
        <field name="model">mysdb.bulk.period.creation.wizard</field>
        <field name="arch" type="xml">
            <form string="Bulk Period Creation">
                <group>
                    <group string="Step 1: Select Target">
                        <field name="target_type" widget="radio"/>
                        <field name="project_id" 
                               invisible="target_type != 'project'" 
                               required="target_type == 'project'"/>
                        <field name="marketing_account_id" 
                               invisible="target_type != 'marketing'" 
                               required="target_type == 'marketing'"/>
                    </group>
                    <group string="Step 2: Select Periods">
                        <field name="year"/>
                        <field name="create_yearly"/>
                        <field name="create_monthly"/>
                        <field name="select_specific_months" invisible="not create_monthly"/>
                    </group>
                </group>
                
                <group string="Select Specific Months" invisible="not create_monthly or not select_specific_months">
                    <group>
                        <field name="month_01" string="January"/>
                        <field name="month_02" string="February"/>
                        <field name="month_03" string="March"/>
                        <field name="month_04" string="April"/>
                        <field name="month_05" string="May"/>
                        <field name="month_06" string="June"/>
                    </group>
                    <group>
                        <field name="month_07" string="July"/>
                        <field name="month_08" string="August"/>
                        <field name="month_09" string="September"/>
                        <field name="month_10" string="October"/>
                        <field name="month_11" string="November"/>
                        <field name="month_12" string="December"/>
                    </group>
                </group>
                
                <group>
                    <group string="Step 3: Financial Values">
                        <field name="target_amount" widget="monetary"/>
                        <field name="distribution_type"/>
                    </group>
                    <group string="Cost Calculation">
                        <field name="cost_calculation_type" widget="radio"/>
                        <field name="cost_percentage" 
                               invisible="cost_calculation_type != 'percentage'" 
                               required="cost_calculation_type == 'percentage'"
                               widget="percentage"/>
                        <field name="cost_amount" 
                               widget="monetary"
                               readonly="cost_calculation_type == 'percentage'"/>
                    </group>
                </group>
                
                <group string="Preview">
                    <group>
                        <div class="alert alert-info" style="margin-bottom: 0;">
                            <strong>Periods to Create: <field name="preview_count" class="oe_inline"/> record(s)</strong>
                        </div>
                    </group>
                    <group>
                        <field name="preview_text" nolabel="1" readonly="1" 
                               widget="text" 
                               style="font-family: monospace; white-space: pre-wrap;"/>
                    </group>
                </group>
                
                <footer>
                    <button name="action_create_periods" string="Create Periods" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_mysdb_bulk_period_creation" model="ir.actions.act_window">
        <field name="name">Bulk Create Periods</field>
        <field name="res_model">mysdb.bulk.period.creation.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>

