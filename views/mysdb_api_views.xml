<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_mysdb_api_source_tree" model="ir.ui.view">
        <field name="name">mysdb.api.source.tree</field>
        <field name="model">mysdb.api.source</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="target_model_id"/>
                <field name="active"/>
                <field name="last_sync_at"/>
                <field name="last_sync_status"/>
                <field name="last_sync_count"/>
            </tree>
        </field>
    </record>

    <record id="view_mysdb_api_source_form" model="ir.ui.view">
        <field name="name">mysdb.api.source.form</field>
        <field name="model">mysdb.api.source</field>
        <field name="arch" type="xml">
            <form string="API Source">
                <header>
                    <button name="action_sync" type="object" string="▶ Sync Now" class="btn-primary"
                            invisible="sync_in_progress"/>
                    <button name="action_sync_full" type="object" string="🔄 Full Re-sync" class="btn-secondary"
                            invisible="sync_in_progress or last_sync_status != 'error'"
                            confirm="This will start syncing from page 1 (ignoring any resume point). Continue?"/>
                    <button name="action_clear_sync_lock" type="object"
                            string="🔓 Clear Sync Lock" class="btn-warning"
                            invisible="not sync_in_progress"
                            confirm="This will clear the sync lock. Only use if the sync is stuck. Continue?"/>
                    <button name="action_sync_details" type="object"
                            string="Sync Order Details"
                            class="btn-secondary"
                            invisible="not detail_sync_enabled"/>
                    <button name="action_build_product_catalog" type="object"
                            string="Build Product Catalog"
                            class="btn-secondary"
                            invisible="not detail_sync_enabled"
                            confirm="This will create mysdb.product records from unique products found in order details. Continue?"/>
                    <button name="action_deduplicate" type="object"
                            string="🔄 Remove Duplicates"
                            class="btn-warning"
                            confirm="This will find and remove duplicate records based on the Unique Field. Keeps the oldest record. Continue?"/>
                </header>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="active"/>
                        <field name="auto_sync" widget="boolean_toggle"/>
                        <field name="sync_in_progress" invisible="1"/>
                        <field name="sync_started_at" invisible="1"/>
                    </group>
                    <group string="Auto Sync Schedule" invisible="not auto_sync">
                        <div class="d-flex align-items-center">
                            <span class="me-2">Sync Every</span>
                            <field name="auto_sync_interval" class="oe_inline" style="width: 60px;"/>
                            <field name="auto_sync_interval_type" class="oe_inline ms-2"/>
                        </div>
                        <field name="auto_sync_next_run"/>
                    </group>
                    <group>
                        <field name="company_id" options="{'no_create': True}" groups="base.group_multi_company"/>
                    </group>
                    <group string="Connection">
                        <field name="api_url"/>
                        <field name="request_url"/>
                        <field name="bearer_token" password="True"/>
                        <field name="custom_headers" widget="text"
                               placeholder='{"X-Manager-Token": "...", "Accept-Language": "ar"}'/>
                        <field name="connect_timeout"/>
                        <field name="request_timeout"/>
                    </group>
                    <group string="Date Filter">
                        <field name="filter_date_from"/>
                        <field name="filter_date_to"/>
                        <field name="filter_date_from_param"/>
                        <field name="filter_date_to_param"/>
                        <field name="filter_date_format"/>
                    </group>
                    <group string="Status Filter">
                        <field name="filter_status_name_enabled"/>
                        <field name="filter_status_name" invisible="not filter_status_name_enabled"/>
                    </group>
                    <group string="Target">
                        <field name="target_model_id" required="1"/>
                        <field name="unique_field"/>
                        <field name="data_root_key" placeholder="orders, data, items, etc."/>
                        <field name="mapping_json" widget="text"
                               placeholder='{"order_id":"id", "customer_name":"customer.name", "store_id":{"const":"123"}}'/>
                    </group>
                    <group string="Pagination">
                        <field name="enable_pagination"/>
                        <field name="pagination_start" invisible="not enable_pagination"/>
                        <field name="pagination_zero_based" invisible="not enable_pagination"/>
                                <field name="page_size" invisible="not enable_pagination"/>
                                <field name="page_request_delay" invisible="not enable_pagination"/>
                    </group>
                    <separator string="Detail Sync (per-record child fetching)"/>
                    <group>
                        <field name="detail_sync_enabled" widget="boolean_toggle"/>
                    </group>
                    <group string="Detail Configuration" invisible="not detail_sync_enabled">
                        <field name="detail_url_pattern"
                               placeholder="https://api.zid.sa/v1/managers/store/orders/{id}/view"/>
                        <field name="detail_parent_id_field" placeholder="order_id"/>
                        <field name="detail_parent_domain" widget="text"
                               placeholder='[["store_id","=","1170879"]]'/>
                        <field name="detail_data_root_key" placeholder="order.products"/>
                        <field name="detail_target_model_id"/>
                        <field name="detail_unique_field" placeholder="order_detail_uuid"/>
                        <field name="detail_mapping_json" widget="text"
                               placeholder='{"order_linked_id":"parent:id","product_name":"name","product_sku":"sku","total":"total"}'/>
                        <field name="detail_request_delay"/>
                    </group>
                    <group string="Detail Sync Status" invisible="not detail_sync_enabled">
                        <field name="detail_last_sync_at" readonly="1"/>
                        <field name="detail_last_sync_status" readonly="1"/>
                        <field name="detail_last_sync_count" readonly="1"/>
                        <field name="detail_last_sync_message" readonly="1"/>
                    </group>
                    <group string="Dump Raw JSON">
                        <field name="dump_json"/>
                        <field name="dump_directory" invisible="not dump_json"/>
                        <field name="dump_file_prefix" invisible="not dump_json"/>
                        <field name="last_dump_file" readonly="1"/>
                        <field name="last_dump_size" readonly="1"/>
                    </group>
                    <group string="Last Sync">
                        <field name="last_sync_at" readonly="1"/>
                        <field name="last_sync_status" readonly="1"/>
                        <field name="last_sync_count" readonly="1"/>
                        <field name="last_sync_page" readonly="1"/>
                        <field name="last_sync_page_items" readonly="1"/>
                        <field name="last_sync_page_created" readonly="1"/>
                        <field name="last_sync_page_updated" readonly="1"/>
                        <field name="last_sync_message" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_mysdb_api_sources" model="ir.actions.act_window">
        <field name="name">API Sources</field>
        <field name="res_model">mysdb.api.source</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>

