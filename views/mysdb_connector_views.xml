<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!--    mysdb connector form view-->
    <record id="mysdb_connector_view_form" model="ir.ui.view">
        <field name="model">mysdb.connector</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_sync_table" type="object" string="Sync Table"
                            class="oe_highlight" invisible="state == 'draft'"/>
                    <button name="action_fetch_data" type="object" string="Fetch Data"
                            class="oe_highlight"/>
                    <button name="action_download_csv" type="object" string="Download CSV"
                            class="btn-primary" invisible="state == 'draft'"/>
                    <button name="action_clean_data" type="object" string="Clean Existing Data"
                            class="btn-secondary" invisible="state == 'draft'"/>
                    <button name="action_reset_connector" type="object" string="Reset Connector"
                            class="btn-danger" invisible="state == 'draft'" confirm="Are you sure you want to clear the sync logs for this table?"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,fetched,sync"/>
                </header>
                <sheet>
                    <group>
                        <group string="Connection Details">
                            <field name="name"/>
                            <field name="credential_id" options="{'no_create': True}"/>
                        </group>
                        <group string="Target Mapping">
                            <field name="sql_table"/>
                            <field name="model_id" options="{'no_create': True}"/>
                            <field name="auto_sync" widget="boolean_toggle"/>
                            <field name="is_fetched" invisible="True"/>
                        </group>
                    </group>
                    <group string="Import Filtering">
                        <field name="filter_query" string="SQL WHERE Filter" placeholder="e.g. status='paid' AND created_at > '2025-01-01'"/>
                        <field name="delete_odoo_records" widget="boolean_toggle"/>
                        <p class="text-muted">
                            Enter the SQL condition to filter records from the source table. 
                            Do NOT include the word 'WHERE'. 
                            Example: <code>status='active'</code>
                        </p>
                    </group>
                    <notebook invisible="is_fetched == False" >
                        <page string="Data Mapping">
                            <field name="sync_ids">
                                <tree create="false" editable="bottom">
                                    <field name="mysql_field" readonly="1" string="MySDB Field"/>
                                    <field name="ir_field_id" options="{'no_create': True}"  />
                                    <field name="ref_table" readonly="1"/>
                                    <field name="ref_col" readonly="1"/>
                                    <field name="ref_col_name" required="ref_col != False"/>
                                    <field name="model_id"  column_invisible="True"/>
                                    <field name="foreign_key"  column_invisible="True"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Sync History">
                            <group>
                                <field name="last_sync_date"/>
                                <field name="last_sync_message"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
    <!--    mysdb connector tree view-->
    <record id="mysdb_connector_view_tree" model="ir.ui.view">
        <field name="model">mysdb.connector</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="credential_id"/>
                <field name="sql_table"/>
                <field name="model_id"/>
            </tree>
        </field>
    </record>
    <!--    mysdb connector action-->
    <record id="mysdb_connector_action" model="ir.actions.act_window">
        <field name="name">Connector</field>
        <field name="res_model">mysdb.connector</field>
        <field name="view_mode">tree,form</field>
    </record>
    <!--    mysdb connector menu - Moved to mysdb_menus.xml to avoid forward reference -->
</odoo>
