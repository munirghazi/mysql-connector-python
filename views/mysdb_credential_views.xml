<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!--    mysdb credential form view-->
    <record id="mysdb_credential_view_form" model="ir.ui.view">
        <field name="model">mysdb.credential</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_connect" type="object" string="Test Connection"
                            class="oe_highlight"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="host"/>
                        </group>
                        <group>
                            <field name="user"/>
                            <field name="password" password="True"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <!--    mysdb credential tree view-->
    <record id="mysdb_credential_view_tree" model="ir.ui.view">
        <field name="model">mysdb.credential</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="host"/>
                <field name="user"/>
            </tree>
        </field>
    </record>
    <!--    mysdb credential action-->
    <record id="mysdb_credential_action" model="ir.actions.act_window">
        <field name="name">Credentials</field>
        <field name="res_model">mysdb.credential</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!--    Imported Data action-->
    <record id="action_imported_data" model="ir.actions.act_window">
        <field name="name">Imported Data Logs</field>
        <field name="res_model">imported.data</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!--    Imported Data tree view-->
    <record id="view_imported_data_tree" model="ir.ui.view">
        <field name="name">imported.data.tree</field>
        <field name="model">imported.data</field>
        <field name="arch" type="xml">
            <tree string="Imported Data Logs" create="false" edit="false">
                <field name="model_id"/>
                <field name="mysdb_table"/>
                <field name="mysdb_ref"/>
                <field name="odoo_ref"/>
                <field name="log_note"/>
            </tree>
        </field>
    </record>

    <!--    Imported Data form view-->
    <record id="view_imported_data_form" model="ir.ui.view">
        <field name="name">imported.data.form</field>
        <field name="model">imported.data</field>
        <field name="arch" type="xml">
            <form string="Imported Data Log" create="false" edit="false">
                <sheet>
                    <group>
                        <group>
                            <field name="model_id"/>
                            <field name="mysdb_table"/>
                        </group>
                        <group>
                            <field name="mysdb_ref"/>
                            <field name="odoo_ref"/>
                        </group>
                    </group>
                    <group>
                        <field name="log_note"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
