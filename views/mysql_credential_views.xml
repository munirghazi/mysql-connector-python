<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!--    mysql credential form view-->
    <record id="mysql_credential_view_form" model="ir.ui.view">
        <field name="model">mysql.credential</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_connect" type="object" string="Test Connection"
                            class="oe_highlight"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="host"/>
                        </group>
                        <group>
                            <field name="user"/>
                            <field name="password" password="True"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <!--    mysql credential tree view-->
    <record id="mysql_credential_view_tree" model="ir.ui.view">
        <field name="model">mysql.credential</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="host"/>
                <field name="user"/>
            </tree>
        </field>
    </record>
    <!--    mysql credential action-->
    <record id="mysql_credential_action" model="ir.actions.act_window">
        <field name="name">Credentials</field>
        <field name="res_model">mysql.credential</field>
        <field name="view_mode">tree,form</field>
    </record>
    <!--    mysql root menu-->
    <menuitem id="mysql_connector_menu_root"
              name="Mysql Connector" groups="base.group_system"
              web_icon="odoo_mysql_connector,static/description/icon.png"/>
    <!--    mysql configuration menu-->
    <menuitem id="mysql_connector_menu_configuration"
              name="Configuration"
              parent="mysql_connector_menu_root"/>
    <!--    mysql credential menu-->
    <menuitem id="mysql_credential_menu"
              name="Credentials"
              action="mysql_credential_action"
              parent="mysql_connector_menu_configuration"
              sequence="7"/>
</odoo>
