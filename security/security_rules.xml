        <!-- ════════════════════════════════════════════════════════════════
             Multi-Company Record Rules (configuration models only)
             Users see records from their own company OR shared (no company).
             ════════════════════════════════════════════════════════════════ -->
        <record id="rule_mysdb_credential_company" model="ir.rule">
            <field name="name">MySDB Credential: multi-company</field>
            <field name="model_id" ref="model_mysdb_credential"/>
            <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
            <field name="global" eval="True"/>
        </record>

