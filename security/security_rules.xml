        <!-- ════════════════════════════════════════════════════════════════
             Module Category & Security Groups
             ════════════════════════════════════════════════════════════════ -->
        <record id="module_category_mysdb" model="ir.module.category">
            <field name="name">MySDB Dashboard</field>
            <field name="description">Access rights for MySDB Reporting module.</field>
            <field name="sequence">100</field>
        </record>

        <!-- User: read-only on data, reports; limited write on tools -->
        <record id="group_mysdb_user" model="res.groups">
            <field name="name">User</field>
            <field name="category_id" ref="module_category_mysdb"/>
            <field name="comment">Read data, view reports, run tools.</field>
        </record>

        <!-- Manager: full CRUD on data models, tools, reports (implies User) -->
        <record id="group_mysdb_manager" model="res.groups">
            <field name="name">Manager</field>
            <field name="category_id" ref="module_category_mysdb"/>
            <field name="implied_ids" eval="[(4, ref('group_mysdb_user'))]"/>
            <field name="comment">Full access to all MySDB data and reports.</field>
        </record>

        <!-- Admin (Settings) users automatically get MySDB Manager access -->
        <record id="base.group_system" model="res.groups">
            <field name="implied_ids" eval="[(4, ref('group_mysdb_manager'))]"/>
        </record>

